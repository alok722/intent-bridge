GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# Optional: log inference metadata (no user content) to Firestore via Firebase Admin
# ENABLE_FIRESTORE_LOG=true
# FIREBASE_PROJECT_ID=your_gcp_project_id

# Optional: Google Cloud Translation API — normalize free-text to English before Gemini (ADC on Cloud Run)
# ENABLE_CLOUD_TRANSLATE=true
# GOOGLE_CLOUD_PROJECT=your_gcp_project_id

# Optional: emit JSON lines for Cloud Logging (also auto-on when K_SERVICE is set, e.g. Cloud Run)
# ENABLE_STRUCTURED_LOG=true
